# Supabase (Project Settings → API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Use either name — dashboard may show "Publishable key" (new) or "anon" (legacy):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Server-only secret — never expose in the browser:
SUPABASE_SERVICE_ROLE_KEY=your_secret_or_service_role_key
# SUPABASE_SECRET_KEY=your_secret_key

# Admin inbox login (/admin/login)
ADMIN_PASSWORD=change_me_to_a_strong_password
ADMIN_SESSION_SECRET=change_me_to_a_long_random_string
# Comma-separated — who may sign in (same password for all)
ADMIN_ALLOWED_EMAILS=info@nulientransportation.com,laharikarrotu24@gmail.com
